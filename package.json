    "render:next_scenegraph": "cd tools/md2html && bun render.ts ../../NEXT_SCENEGRAPH.md ../../_site/NEXT_SCENEGRAPH.html",
    "view": "cd tools/md2html && bun run view",
    "view:scenegraph": "cd tools/md2html && bun run view:scenegraph",
    "view:ego": "cd tools/md2html && bun run view:ego",
    "view:next_scenegraph": "cd tools/md2html && bun run view:next_scenegraph",
    "view:map-demo": "cd tools/map-demo && bun run view",
    "doxygen": "bun tools/doxygen/render.ts",
    "infra": "bun tools/infra.ts",
    "docker:build": "bun tools/infra.ts docker build",
    "docker:run": "bun tools/infra.ts docker run",
    "test:build": "bun src/cli/index.ts docker-build",
    "test:run": "bun src/cli/index.ts test-run",
    "test:status": "bun src/cli/index.ts test-status",
    "test:stop": "bun src/cli/index.ts test-stop",
    "test:smoke": "bun src/cli/index.ts test-smoke",
    "test:validate": "bun src/cli/index.ts test-validate",
    "test:scale": "bun src/cli/index.ts test-scale",
